{
  "name": "repo-agent-extension",
  "displayName": "Repo Agent",
  "description": "Integrate Repo Agent for autonomous code development",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:repo-agent.startChat"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "repo-agent.startChat",
        "title": "Start Repo Agent Chat"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "repo-agent.startChat"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.74.0",
    "@types/node": "16.x",
    "typescript": "^4.9.4"
  }
}